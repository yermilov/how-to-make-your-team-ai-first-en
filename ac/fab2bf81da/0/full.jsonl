currentSlide >= slides.findIndex(s => s.id === 'context-principles') && (\n        <SlideProgress current={currentSlide + 1} total={slides.length} slideId={activeSlide.id} />\n      )}\n      {currentSlide === 0 && !slideInteracted && <OnboardingTooltip />}\n      {activeSlide.tooltip &&\n        (activeSlide.maxRevealStages\n          ? revealStage < activeSlide.maxRevealStages\n          : !slideInteracted) && (\n        <ContextTooltip>{activeSlide.tooltip}</ContextTooltip>\n      )}\n      {currentSlide === 0 && !slideInteracted && (\n        <PointerTooltip position=\"left\">\n          <div className=\"pointer-tooltip-header\">\n            <span className=\"onboarding-tooltip-icon\">?</span>\n            <span className=\"pointer-tooltip-title\">Timer</span>\n          </div>\n          <p className=\"pointer-tooltip-text\">\n            helps track presentation duration. press <code>[start]</code> or type <code>start</code> to begin\n          </p>\n        </PointerTooltip>\n      )}\n      <TerminalInput\n        onCommand={handleCommand}\n        onInputChange={setInputText}\n        onArrowLeft={prevSlide}\n        onArrowRight={nextSlide}\n        placeholder=\"type anything to continue, 'prev' to go back, or slide number...\"\n      />\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":66,"oldLines":9,"newStart":66,"newLines":6,"lines":["   // Reset interaction state when slide changes","   useEffect(() => {","     setSlideInteracted(false);","-    if (slides[currentSlide]?.id === 'intro') {","-      setActivatedTools(new Set());","-    }","   }, [currentSlide]);"," ","   // Timer state with localStorage persistence"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"44a5f503-f9c1-4d36-a7b7-e8d0bef0cd45"}
