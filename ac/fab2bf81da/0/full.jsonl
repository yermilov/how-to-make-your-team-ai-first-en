{"parentUuid":"571ccc69-53ce-4a13-b4a5-323d046bed67","isSidechain":false,"userType":"external","cwd":"/Users/yarikyermilov/src/how-to-make-your-team-ai-first-en","sessionId":"789c56d5-eaa6-497c-adc2-071e37df3ae0","version":"2.1.70","gitBranch":"main","slug":"fizzy-swimming-lark","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0153Q7UHvWn1P8qedWMJCA9K","type":"tool_result","content":"     1→import { useState, useEffect, useCallback } from 'react';\n     2→import { PresentationProps } from '../types/slides';\n     3→import { useSlideNavigation } from '../hooks/useSlideNavigation';\n     4→import { useTouchNavigation } from '../hooks/useTouchNavigation';\n     5→import { Slide } from './Slide';\n     6→import { TerminalInput } from './TerminalInput';\n     7→import { SlideProgress } from './SlideProgress';\n     8→import { Timer } from './Timer';\n     9→import { OnboardingTooltip, ContextTooltip } from './OnboardingTooltip';\n    10→import { PointerTooltip } from './PointerTooltip';\n    11→\n    12→const TIMER_STARTED_AT_KEY = 'timerStartedAt';\n    13→const TIMER_ACCUMULATED_KEY = 'timerAccumulated';\n    14→\n    15→// Tool keywords for activation persistence\n    16→const TOOL_KEYWORDS: Record<string, string[]> = {\n    17→  claude: ['claude', 'claude code', 'anthropic'],\n    18→  codex: ['codex', 'openai'],\n    19→  cursor: ['cursor'],\n    20→  amp: ['amp', 'sourcegraph'],\n    21→  gemini: ['gemini', 'gemini-cli', 'google'],\n    22→  copilot: ['copilot', 'github copilot'],\n    23→  lovable: ['lovable'],\n    24→  other: ['?', 'other', 'else', 'something'],\n    25→};\n    26→\n    27→// Find which tool IDs match the input\n    28→function getMatchingToolIds(input: string): string[] {\n    29→  if (!input.trim()) return [];\n    30→  const normalizedInput = input.toLowerCase().trim();\n    31→  return Object.entries(TOOL_KEYWORDS)\n    32→    .filter(([, keywords]) =>\n    33→      keywords.some(kw => normalizedInput.includes(kw) || kw.includes(normalizedInput))\n    34→    )\n    35→    .map(([id]) => id);\n    36→}\n    37→\n    38→function getInitialTimerState(): { seconds: number; running: boolean } {\n    39→  const startedAt = localStorage.getItem(TIMER_STARTED_AT_KEY);\n    40→  const accumulated = parseInt(localStorage.getItem(TIMER_ACCUMULATED_KEY) || '0', 10);\n    41→\n    42→  if (startedAt) {\n    43→    const elapsed = Math.floor((Date.now() - parseInt(startedAt, 10)) / 1000);\n    44→    return { seconds: accumulated + elapsed, running: true };\n    45→  }\n    46→  return { seconds: accumulated, running: false };\n    47→}\n    48→\n    49→export function Presentation({ slides, initialSlide = 0 }: PresentationProps) {\n    50→  const { currentSlide, handleCommand: handleNavCommand, revealStage, nextSlide, prevSlide } = useSlideNavigation(\n    51→    slides.length,\n    52→    initialSlide\n    53→  );\n    54→\n    55→  const { containerRef } = useTouchNavigation({ nextSlide, prevSlide });\n    56→\n    57→  // Track current input text for interactive slides\n    58→  const [inputText, setInputText] = useState('');\n    59→\n    60→  // Track activated tools (persists after Enter)\n    61→  const [activatedTools, setActivatedTools] = useState<Set<string>>(new Set());\n    62→\n    63→  // Track if user has interacted on current slide (for tooltips)\n    64→  const [slideInteracted, setSlideInteracted] = useState(false);\n    65→\n    66→  // Reset interaction state when slide changes\n    67→  useEffect(() => {\n    68→    setSlideInteracted(false);\n    69→  }, [currentSlide]);\n    70→\n    71→  // Timer state with localStorage persistence\n    72→  const [timerSeconds, setTimerSeconds] = useState(() => getInitialTimerState().seconds);\n    73→  const [timerRunning, setTimerRunning] = useState(() => getInitialTimerState().running);\n    74→\n    75→  useEffect(() => {\n    76→    if (!timerRunning) return;\n    77→\n    78→    const interval = setInterval(() => {\n    79→     